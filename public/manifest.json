{
  "manifest_version": 3,
  "name": "Paper Browser",
  "version": "0.1.0",
  "description": "Annotate PDF citations and follow cited PDFs in the same tab.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Annotate this PDF",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "options_page": "extension-options.html",
  "permissions": ["activeTab", "tabs", "downloads", "storage"],
  "host_permissions": [
    "https://arxiv.org/*",
    "https://export.arxiv.org/*",
    "https://api.crossref.org/*",
    "https://api.openalex.org/*",
    "https://api.unpaywall.org/*",
    "https://api.semanticscholar.org/*",
    "https://api.semble.so/*",
    "https://duckduckgo.com/*",
    "https://doi.org/*",
    "https://www.nber.org/*",
    "https://nber.org/*",
    "https://papers.nips.cc/*",
    "https://papers.neurips.cc/*",
    "https://proceedings.neurips.cc/*",
    "https://datasets-benchmarks-proceedings.neurips.cc/*",
    "https://aclanthology.org/*",
    "https://ieeexplore.ieee.org/*",
    "https://scholar.google.com/*"
  ]
}
